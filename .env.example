# Copy this file to .env and edit before running `docker compose up`.

# Host port to expose the app on.
PORT=8000

# Host directory for the SQLite database. Will be created automatically if it doesn't exist.
# Use an absolute path to pin it to a specific location, e.g. /srv/wordplay/data
DB_DIR=./data

# Django secret key — change this for any non-local deployment.
SECRET_KEY=change-me-for-real-deployments
